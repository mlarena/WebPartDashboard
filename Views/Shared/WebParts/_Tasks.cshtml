@model List<WebPartDashboard.Models.Entities.TaskItem>
@{
    // Генерация уникального ID для каждого экземпляра веб-части, 
    // чтобы избежать конфликтов при наличии нескольких таких частей на дашборде.
    var uniqueId = Guid.NewGuid().ToString("N");
}
<!-- Основной контейнер веб-части задач с использованием Flexbox для динамической высоты -->
<div class="tasks-webpart d-flex flex-column h-100" id="tasks-container-@uniqueId">
    
    <!-- Панель управления: кнопки и выбор размера страницы -->
    <div class="mb-2">
        <div class="d-flex justify-content-between align-items-center">
            <div class="btn-group">
                <button class="btn btn-primary btn-sm btn-add-task">
                    <i class="bi bi-plus-lg"></i> Добавить задачу
                </button>
                <button class="btn btn-outline-secondary btn-sm btn-refresh-tasks">
                    <i class="bi bi-arrow-repeat"></i> Обновить
                </button>
            </div>
            
            <div class="d-flex align-items-center">
                <label class="me-2 small text-muted">Показывать по:</label>
                <select class="form-select form-select-sm select-page-size" style="width: auto;">
                    <option value="10" selected>10</option>
                    <option value="20">20</option>
                    <option value="50">50</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Верхний блок пагинации -->
    <div class="pagination-container top-pagination mb-2">
        <div class="d-flex justify-content-between align-items-center px-2">
            <div class="text-muted small">
                Показано <span class="pagination-info">0-0 из 0</span>
            </div>
            <nav>
                <ul class="pagination pagination-sm mb-0 tasks-pagination"></ul>
            </nav>
        </div>
    </div>

    <!-- Таблица задач с прокруткой, занимающая всё свободное место (flex-grow-1) -->
    <div class="table-responsive flex-grow-1" style="overflow-y: auto;">
        <table class="table table-hover table-sm mb-0">
            <thead class="table-light sticky-top">
                <tr>
                    <th style="width: 40px"></th>
                    <th>Название</th>
                    <th>Статус</th>
                    <th>Приоритет</th>
                    <th>Срок</th>
                    <th>Ответственный</th>
                    <th style="width: 80px">Действия</th>
                </tr>
            </thead>
            <tbody class="tasks-table-body">
                <tr>
                    <td colspan="7" class="text-center py-5">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Загрузка...</span>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- Нижний блок пагинации -->
    <div class="pagination-container bottom-pagination mt-3">
        <div class="d-flex justify-content-between align-items-center px-2">
            <div class="text-muted small">
                Показано <span class="pagination-info">0-0 из 0</span>
            </div>
            <nav>
                <ul class="pagination pagination-sm mb-0 tasks-pagination"></ul>
            </nav>
        </div>
    </div>

    <!-- Модальное окно для добавления/редактирования задачи. 
         ID уникален для каждого экземпляра веб-части. -->
    <div class="modal fade task-modal" id="taskModal-@uniqueId" tabindex="-1" role="dialog">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Добавить задачу</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form class="task-form">
                        <input type="hidden" class="task-id" />
                        <div class="mb-3">
                            <label class="form-label">Название *</label>
                            <input type="text" class="form-control task-title" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Описание</label>
                            <textarea class="form-control task-description" rows="3"></textarea>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Статус</label>
                                <select class="form-select task-status">
                                    <option value="0">Новая</option>
                                    <option value="1">В работе</option>
                                    <option value="2">На проверке</option>
                                    <option value="3">Завершена</option>
                                    <option value="4">Отложена</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Приоритет</label>
                                <select class="form-select task-priority">
                                    <option value="0">Низкий</option>
                                    <option value="1">Средний</option>
                                    <option value="2">Высокий</option>
                                    <option value="3">Критический</option>
                                </select>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Срок выполнения</label>
                                <input type="date" class="form-control task-due-date">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Ответственный</label>
                                <input type="text" class="form-control task-assigned-to">
                            </div>
                        </div>
                        <div class="form-check mb-3">
                            <input class="form-check-input task-is-completed" type="checkbox">
                            <label class="form-check-label">Выполнено</label>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="button" class="btn btn-primary btn-save-task">Сохранить</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Изолированный JavaScript для управления логикой веб-части задач
    (function() {
        const containerId = 'tasks-container-@uniqueId';
        const $container = $('#' + containerId);
        const $tableBody = $container.find('.tasks-table-body');
        const $paginations = $container.find('.tasks-pagination');
        const $infos = $container.find('.pagination-info');
        const $pageSizeSelect = $container.find('.select-page-size');
        const $modalEl = $container.find('.task-modal');
        const $form = $container.find('.task-form');

        let currentEditId = null;
        let currentPage = 1;
        let pageSize = 10;
        let totalTasksCount = 0;

        // Получение или инициализация экземпляра модального окна Bootstrap
        function getModalInstance() {
            // Перемещаем модальное окно в body для корректного отображения поверх GridStack
            if (!$modalEl.parent().is('body')) {
                $modalEl.appendTo('body');
            }

            let modal = bootstrap.Modal.getInstance($modalEl[0]);
            if (!modal) {
                modal = new bootstrap.Modal($modalEl[0], {
                    backdrop: 'static',
                    keyboard: true
                });
            }
            return modal;
        }

        // Очистка стилей body после закрытия модального окна
        $modalEl.on('hidden.bs.modal', function () {
            $('.modal-backdrop').remove();
            $('body').removeClass('modal-open').css('padding-right', '');
        });

        // Загрузка списка задач с учетом пагинации
        function loadTasks() {
            const skip = (currentPage - 1) * pageSize;
            $.get('/api/TasksApi/stats', function(stats) {
                totalTasksCount = stats.total;
                $.get('/api/TasksApi', { skip: skip, take: pageSize }, function(tasks) {
                    renderTasks(tasks);
                    renderPagination();
                }).fail(function() {
                    $tableBody.html('<tr><td colspan="7" class="text-center text-danger">Ошибка загрузки задач</td></tr>');
                });
            });
        }

        // Отрисовка кнопок пагинации
        function renderPagination() {
            const totalPages = Math.ceil(totalTasksCount / pageSize);
            if (totalTasksCount === 0) {
                $paginations.empty();
                $infos.text('0-0 из 0');
                return;
            }
            const start = (currentPage - 1) * pageSize + 1;
            const end = Math.min(currentPage * pageSize, totalTasksCount);
            $infos.text(start + '-' + end + ' из ' + totalTasksCount);
            
            let html = '';
            html += '<li class="page-item ' + (currentPage === 1 ? 'disabled' : '') + '"><a class="page-link btn-prev" href="#">&laquo;</a></li>';
            let startPage = Math.max(1, currentPage - 2);
            let endPage = Math.min(totalPages, startPage + 4);
            if (endPage - startPage < 4) startPage = Math.max(1, endPage - 4);
            
            for (let i = startPage; i <= endPage; i++) {
                if (i < 1) continue;
                html += '<li class="page-item ' + (i === currentPage ? 'active' : '') + '"><a class="page-link btn-page" data-page="' + i + '" href="#">' + i + '</a></li>';
            }
            html += '<li class="page-item ' + (currentPage === totalPages ? 'disabled' : '') + '"><a class="page-link btn-next" href="#">&raquo;</a></li>';
            $paginations.html(html);
        }

        // Отрисовка строк таблицы задач
        function renderTasks(tasks) {
            if (!tasks || tasks.length === 0) {
                $tableBody.html('<tr><td colspan="7" class="text-center text-muted py-5"><i class="bi bi-inbox fs-1"></i><p class="mt-2">Нет задач</p></td></tr>');
                return;
            }
            let html = '';
            tasks.forEach(function(task) {
                const statusClass = getStatusClass(task.status);
                const priorityClass = getPriorityClass(task.priority);
                const dueDate = task.dueDate ? new Date(task.dueDate).toLocaleDateString('ru') : '-';
                const descHtml = task.description ? '<br><small class="text-muted">' + escapeHtml(task.description.substring(0, 50)) + '</small>' : '';
                html += '<tr>' +
                    '<td><input type="checkbox" class="task-check" data-id="' + task.id + '" ' + (task.isCompleted ? 'checked' : '') + '></td>' +
                    '<td><strong>' + escapeHtml(task.title) + '</strong>' + descHtml + '</td>' +
                    '<td><span class="badge ' + statusClass + '">' + getStatusText(task.status) + '</span></td>' +
                    '<td><span class="badge ' + priorityClass + '">' + getPriorityText(task.priority) + '</span></td>' +
                    '<td>' + dueDate + '</td>' +
                    '<td>' + escapeHtml(task.assignedTo || '-') + '</td>' +
                    '<td>' +
                        '<button class="btn btn-sm btn-outline-secondary btn-edit-task" data-id="' + task.id + '"><i class="bi bi-pencil"></i></button> ' +
                        '<button class="btn btn-sm btn-outline-danger btn-delete-task" data-id="' + task.id + '"><i class="bi bi-trash"></i></button>' +
                    '</td>' +
                '</tr>';
            });
            $tableBody.html(html);
        }

        // Вспомогательные функции для стилизации статусов и приоритетов
        function getStatusClass(s) { return ['bg-secondary', 'bg-primary', 'bg-warning', 'bg-success', 'bg-danger'][s] || 'bg-secondary'; }
        function getStatusText(s) { return ['Новая', 'В работе', 'На проверке', 'Завершена', 'Отложена'][s] || '-'; }
        function getPriorityClass(p) { return ['bg-info', 'bg-primary', 'bg-warning', 'bg-danger'][p] || 'bg-secondary'; }
        function getPriorityText(p) { return ['Низкий', 'Средний', 'Высокий', 'Критический'][p] || '-'; }
        
        // Безопасное экранирование HTML для предотвращения XSS
        function escapeHtml(t) {
            if (!t) return '';
            const map = { '&': '&', '<': '<', '>': '>', '"': '"', "'": '&#039;' };
            return t.toString().replace(/[&<>"']/g, function(m) { return map[m]; });
        }

        // --- Обработчики событий ---

        $container.on('click', '.btn-add-task', function() {
            currentEditId = null;
            $modalEl.find('.modal-title').text('Добавить задачу');
            $form[0].reset();
            $modalEl.find('.task-id').val('');
            $modalEl.find('.task-is-completed').prop('checked', false);
            $modalEl.find('.task-status').val(0);
            $modalEl.find('.task-priority').val(1);
            getModalInstance().show();
        });

        $container.on('click', '.btn-edit-task', function() {
            const id = $(this).data('id');
            $.get('/api/TasksApi/' + id, function(task) {
                currentEditId = task.id;
                $modalEl.find('.modal-title').text('Редактировать задачу');
                $modalEl.find('.task-id').val(task.id);
                $modalEl.find('.task-title').val(task.title);
                $modalEl.find('.task-description').val(task.description);
                $modalEl.find('.task-status').val(task.status);
                $modalEl.find('.task-priority').val(task.priority);
                $modalEl.find('.task-due-date').val(task.dueDate ? task.dueDate.split('T')[0] : '');
                $modalEl.find('.task-assigned-to').val(task.assignedTo);
                $modalEl.find('.task-is-completed').prop('checked', task.isCompleted);
                getModalInstance().show();
            });
        });

        // Сохранение задачи (POST или PUT)
        $modalEl.find('.btn-save-task').on('click', function() {
            const taskData = {
                id: currentEditId || 0,
                title: $modalEl.find('.task-title').val(),
                description: $modalEl.find('.task-description').val(),
                status: parseInt($modalEl.find('.task-status').val()),
                priority: parseInt($modalEl.find('.task-priority').val()),
                dueDate: $modalEl.find('.task-due-date').val() || null,
                assignedTo: $modalEl.find('.task-assigned-to').val(),
                isCompleted: $modalEl.find('.task-is-completed').is(':checked')
            };
            if (!taskData.title) { alert('Введите название задачи'); return; }
            const method = currentEditId ? 'PUT' : 'POST';
            const url = '/api/TasksApi' + (currentEditId ? '/' + currentEditId : '');
            $.ajax({
                url: url, type: method, contentType: 'application/json', data: JSON.stringify(taskData),
                success: function() {
                    getModalInstance().hide();
                    loadTasks();
                }
            });
        });

        $container.on('click', '.btn-delete-task', function() {
            const id = $(this).data('id');
            if (confirm('Удалить задачу?')) {
                $.ajax({ url: '/api/TasksApi/' + id, type: 'DELETE', success: loadTasks });
            }
        });

        $container.on('change', '.task-check', function() {
            const id = $(this).data('id');
            const isCompleted = $(this).is(':checked');
            $.get('/api/TasksApi/' + id, function(task) {
                task.isCompleted = isCompleted;
                task.status = isCompleted ? 3 : 0;
                $.ajax({
                    url: '/api/TasksApi/' + id, type: 'PUT', contentType: 'application/json',
                    data: JSON.stringify(task), success: loadTasks
                });
            });
        });

        $container.on('click', '.btn-refresh-tasks', loadTasks);
        $pageSizeSelect.on('change', function() { pageSize = parseInt($(this).val()); currentPage = 1; loadTasks(); });
        $container.on('click', '.btn-page', function(e) { e.preventDefault(); currentPage = $(this).data('page'); loadTasks(); });
        $container.on('click', '.btn-prev', function(e) { e.preventDefault(); if (currentPage > 1) { currentPage--; loadTasks(); } });
        $container.on('click', '.btn-next', function(e) { e.preventDefault(); if (currentPage * pageSize < totalTasksCount) { currentPage++; loadTasks(); } });

        // Первичная загрузка данных
        loadTasks();
    })();
</script>

<style>
    .sticky-top { position: sticky; top: 0; z-index: 10; }
    .pagination-container { background: #f8f9fa; padding: 5px 0; border-radius: 4px; }
</style>
