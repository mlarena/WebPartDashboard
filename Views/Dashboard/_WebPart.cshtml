@model WebPart

<div id="webpart-@Model.Id" 
     class="webpart card shadow-sm h-100" 
     data-id="@Model.Id"
     data-type="@Model.Type"
     gs-id="@Model.Id">
    
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-2">
        <h5 class="card-title mb-0">
            <i class="bi @GetWebPartIcon(Model.Type) me-2"></i>
            <span class="webpart-title-text">@Model.Title</span>
        </h5>
        <div class="btn-group btn-group-sm">
            <button class="btn btn-outline-secondary" onclick="refreshWebPart(@Model.Id)" title="Обновить">
                <i class="bi bi-arrow-repeat"></i>
            </button>
            <button class="btn btn-outline-secondary" onclick="editWebPartTitle(@Model.Id)" title="Редактировать заголовок">
                <i class="bi bi-pencil"></i>
            </button>
            <button class="btn btn-outline-danger" onclick="removeWebPart(@Model.Id)" title="Удалить">
                <i class="bi bi-trash"></i>
            </button>
        </div>
    </div>
    
    <div class="card-body webpart-content p-3 d-flex flex-column" style="min-height: 200px; overflow-y: auto;">
        <!-- Сюда будет загружен контент через AJAX -->
        <div class="text-center my-auto">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted small">Загрузка...</p>
        </div>
    </div>
</div>

@functions {
    string GetWebPartIcon(WebPartType type)
    {
        return type switch
        {
            WebPartType.DataTable => "bi-table",
            WebPartType.Chart => "bi-graph-up",
            WebPartType.Informer => "bi-info-circle",
            WebPartType.Tasks => "bi-check2-square",
            WebPartType.Monitoring => "bi-broadcast",
            _ => "bi-grid"
        };
    }
}
