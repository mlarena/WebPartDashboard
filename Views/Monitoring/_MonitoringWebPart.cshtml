@model List<MonitoringPost>
@{
    var uniqueId = Guid.NewGuid().ToString("N");
}

<div class="monitoring-webpart d-flex flex-column h-100" id="monitoring-container-@uniqueId">
    <div class="mb-2">
        <div class="d-flex justify-content-between align-items-center">
            <div class="btn-group">
                <button class="btn btn-primary btn-sm btn-add-post">
                    <i class="bi bi-plus-lg"></i> Добавить пост
                </button>
                <button class="btn btn-outline-secondary btn-sm btn-refresh-monitoring">
                    <i class="bi bi-arrow-repeat"></i> Обновить
                </button>
            </div>
        </div>
    </div>

    <div class="table-responsive flex-grow-1" style="overflow-y: auto;">
        <table class="table table-hover table-sm mb-0">
            <thead class="table-light sticky-top">
                <tr>
                    <th>Название</th>
                    <th>Координаты</th>
                    <th>Тип</th>
                    <th>Статус</th>
                    <th>Датчики</th>
                    <th style="width: 100px">Действия</th>
                </tr>
            </thead>
            <tbody class="monitoring-table-body">
                <tr>
                    <td colspan="6" class="text-center py-5">
                        <div class="spinner-border text-primary"></div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- Модальное окно для поста -->
    <div class="modal fade post-modal" id="postModal-@uniqueId" tabindex="-1" role="dialog">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Пост мониторинга</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form class="post-form">
                        <input type="hidden" class="post-id" />
                        <div class="mb-3">
                            <label class="form-label">Название *</label>
                            <input type="text" class="form-control post-name" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Описание</label>
                            <textarea class="form-control post-description" rows="2"></textarea>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Долгота</label>
                                <input type="number" step="any" class="form-control post-longitude">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Широта</label>
                                <input type="number" step="any" class="form-control post-latitude">
                            </div>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input post-is-mobile" type="checkbox">
                            <label class="form-check-label">Мобильный пост</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input post-is-active" type="checkbox" checked>
                            <label class="form-check-label">Активен</label>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="button" class="btn btn-primary btn-save-post">Сохранить</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    (function() {
        const containerId = 'monitoring-container-@uniqueId';
        const $container = $('#' + containerId);
        const $tableBody = $container.find('.monitoring-table-body');
        const $postModalEl = $container.find('.post-modal');

        let currentPostId = null;

        function getModalInstance(el) {
            if (!el.parent().is('body')) el.appendTo('body');
            let modal = bootstrap.Modal.getInstance(el[0]);
            if (!modal) modal = new bootstrap.Modal(el[0], { backdrop: 'static' });
            return modal;
        }

        function loadPosts() {
            $.get('/api/MonitoringApi/posts', function(posts) {
                renderPosts(posts);
            });
        }

        function renderPosts(posts) {
            if (!posts || posts.length === 0) {
                $tableBody.html('<tr><td colspan="6" class="text-center py-4 text-muted">Нет постов</td></tr>');
                return;
            }
            let html = '';
            posts.forEach(function(post) {
                html += '<tr>' +
                    '<td><strong>' + escapeHtml(post.name) + '</strong></td>' +
                    '<td>' + (post.longitude || '-') + ', ' + (post.latitude || '-') + '</td>' +
                    '<td>' + (post.isMobile ? '<span class="badge bg-info">Мобильный</span>' : '<span class="badge bg-secondary">Стационарный</span>') + '</td>' +
                    '<td>' + (post.isActive ? '<span class="text-success">● Активен</span>' : '<span class="text-danger">○ Неактивен</span>') + '</td>' +
                    '<td><span class="badge bg-primary">' + (post.sensors ? post.sensors.length : 0) + '</span></td>' +
                    '<td>' +
                        '<button class="btn btn-sm btn-outline-secondary btn-edit-post" data-id="' + post.id + '"><i class="bi bi-pencil"></i></button> ' +
                        '<button class="btn btn-sm btn-outline-danger btn-delete-post" data-id="' + post.id + '"><i class="bi bi-trash"></i></button>' +
                    '</td>' +
                '</tr>';
            });
            $tableBody.html(html);
        }

        function escapeHtml(t) {
            if (!t) return '';
            const map = { '&': '&', '<': '<', '>': '>', '"': '"', "'": '&#039;' };
            return t.toString().replace(/[&<>"']/g, function(m) { return map[m]; });
        }

        $container.on('click', '.btn-add-post', function() {
            currentPostId = null;
            $postModalEl.find('.modal-title').text('Добавить пост');
            $postModalEl.find('.post-form')[0].reset();
            getModalInstance($postModalEl).show();
        });

        $container.on('click', '.btn-edit-post', function() {
            const id = $(this).data('id');
            $.get('/api/MonitoringApi/posts/' + id, function(post) {
                currentPostId = post.id;
                $postModalEl.find('.modal-title').text('Редактировать пост');
                $postModalEl.find('.post-name').val(post.name);
                $postModalEl.find('.post-description').val(post.description);
                $postModalEl.find('.post-longitude').val(post.longitude);
                $postModalEl.find('.post-latitude').val(post.latitude);
                $postModalEl.find('.post-is-mobile').prop('checked', post.isMobile);
                $postModalEl.find('.post-is-active').prop('checked', post.isActive);
                getModalInstance($postModalEl).show();
            });
        });

        $postModalEl.find('.btn-save-post').on('click', function() {
            const data = {
                id: currentPostId || 0,
                name: $postModalEl.find('.post-name').val(),
                description: $postModalEl.find('.post-description').val(),
                longitude: parseFloat($postModalEl.find('.post-longitude').val()) || null,
                latitude: parseFloat($postModalEl.find('.post-latitude').val()) || null,
                isMobile: $postModalEl.find('.post-is-mobile').is(':checked'),
                isActive: $postModalEl.find('.post-is-active').is(':checked')
            };
            if (!data.name) { alert('Введите название'); return; }
            const method = currentPostId ? 'PUT' : 'POST';
            const url = '/api/MonitoringApi/posts' + (currentPostId ? '/' + currentPostId : '');
            $.ajax({
                url: url, type: method, contentType: 'application/json', data: JSON.stringify(data),
                success: function() { getModalInstance($postModalEl).hide(); loadPosts(); }
            });
        });

        $container.on('click', '.btn-delete-post', function() {
            const id = $(this).data('id');
            if (confirm('Удалить пост?')) {
                $.ajax({ url: '/api/MonitoringApi/posts/' + id, type: 'DELETE', success: loadPosts });
            }
        });

        $container.on('click', '.btn-refresh-monitoring', loadPosts);

        loadPosts();
    })();
</script>
